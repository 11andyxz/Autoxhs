# 复制为 .env.local 后填入真实值。.env.local 已被 .gitignore 忽略,不会提交。
# 这些变量只在服务器端使用,严禁加 NEXT_PUBLIC_ 前缀(否则会暴露到浏览器)。

# OpenAI API Key(仅服务器端)
OPENAI_API_KEY=

# 使用的模型 ID。默认 gpt-5.5;只改这里即可切换模型,代码里不写死。
OPENAI_MODEL=gpt-5.5

# MySQL(收费计算器的客户/历史数据)。仅服务器端使用,切勿加 NEXT_PUBLIC_。
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
