# 复制为 .env.local 后填入真实值。.env.local 已被 .gitignore 忽略,不会提交。
# 这些变量只在服务器端使用,严禁加 NEXT_PUBLIC_ 前缀(否则会暴露到浏览器)。

# OpenAI API Key(仅服务器端)
OPENAI_API_KEY=

# 使用的模型 ID。默认 gpt-5.5;只改这里即可切换模型,代码里不写死。
OPENAI_MODEL=gpt-5.5

# MySQL(收费计算器的客户/历史数据)。仅服务器端使用,切勿加 NEXT_PUBLIC_。
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# 本地 rednote 服务(Js-Reverse)地址,供小红书「从链接导入」使用
REDNOTE_API_BASE=http://127.0.0.1:3456

# === 「每天自动评论」定时任务(launchd + scripts/engageAuto.ts)。全部可选,不设即用安全默认值 ===
# 总开关:必须显式设为 1 才会真正发评论。默认(留空/0)只会打印提示并退出,绝不发布。
ENGAGE_AUTO_ENABLED=0
# 每天最多评论多少篇(1~20,默认 10)
ENGAGE_AUTO_COUNT=10
# 推荐信息流翻页数(1~3,默认 2)
ENGAGE_AUTO_PAGES=2
# 每篇之间的随机间隔秒数(默认 4~15;越大越不易被风控)
ENGAGE_AUTO_MIN_INTERVAL_SEC=4
ENGAGE_AUTO_MAX_INTERVAL_SEC=15
# 两轮之间至少间隔多少小时(滚动闸门,默认 24)
ENGAGE_AUTO_INTERVAL_HOURS=24
# 是否给自己这条评论点赞 / 给帖子点赞(默认都开;设 0 关闭)
ENGAGE_AUTO_LIKE_COMMENT=1
ENGAGE_AUTO_LIKE_NOTE=1
# 可选:评论风格/额外说明(<=200 字),留空则按默认「真诚正向、读者视角」
ENGAGE_AUTO_STYLE_HINT=

# 本地 Indeed 自动化服务(Js-Reverse/sites/indeed)地址,供「一键投递 Indeed」使用
INDEED_API_BASE=http://127.0.0.1:3457

# 「雇员信息」上传文件的存储根目录(可选)。
# 留空则默认存到项目目录下的 uploads/(已被 .gitignore 忽略)。
# 文件按 <root>/employee/<雇员id>/<分类>/<文件名> 归档。
EMPLOYEE_UPLOAD_DIR=

# === 「工作邮件自动发送」的 Gmail 发信凭据(仅服务器端) ===
# 发件邮箱(同时用于 SMTP 登录),如 andy@adxztech.com
GMAIL_USER=
# Google 账号的「应用专用密码」(App Password):需先开启两步验证,再到
# https://myaccount.google.com/apppasswords 生成 16 位密码填在这里(可带空格)。
GMAIL_APP_PASSWORD=
# 可选:发件人显示名,默认 "Andy Xiong"
GMAIL_FROM_NAME=

# === 公网部署(如 tools.adxztech.com)才需要;本地不设 → 不启用,本机使用不受影响 ===
# 访问密码:设了就全站需要登录(middleware 校验)。公网部署务必设一个强密码。
APP_PASSWORD=
# 部署范围:设为 public 时只放行「面试/简历」相关路径,其它工具一律 404
#(雇员PII/财务/发邮件/小红书/Indeed 都不对公网暴露)。此项会内联到浏览器,只放这一个标志、无敏感值。
NEXT_PUBLIC_DEPLOY_MODE=
