{
  "name": "autoxhs-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/copy-pdf-worker.mjs",
    "dev": "next dev -p 3100",
    "predev:verify": "node scripts/copy-pdf-worker.mjs",
    "dev:verify": "NEXT_DIST_DIR=.next-verify next dev -p 3111",
    "prebuild": "node scripts/copy-pdf-worker.mjs",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "engage:auto": "tsx scripts/engageAuto.ts",
    "engage:auto:dry": "tsx scripts/engageAuto.ts --dry-run"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@xmldom/xmldom": "^0.8.13",
    "docx": "^9.7.1",
    "docx-preview": "^0.4.0",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "mysql2": "^3.11.0",
    "next": "^15.1.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.77.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^6.1.200",
    "puppeteer-core": "^25.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-fsrs": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.24",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.1",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
